<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Task"
            android:textColor="@color/color_text_primary"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Task Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_task_name"
            style="@style/Widget.SSL.TextInputLayout"
            android:layout_marginBottom="@dimen/spacing_md">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTaskName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Style No -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_style_no"
            style="@style/Widget.SSL.TextInputLayout"
            android:layout_marginBottom="@dimen/spacing_md">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStyleNo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapCharacters" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Details -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_details"
            style="@style/Widget.SSL.TextInputLayout"
            android:layout_marginBottom="@dimen/spacing_md">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Manager / Team Assignment (Visible to Admins only) -->
        <LinearLayout
            android:id="@+id/layoutManagerSelection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assign to Team / Manager"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_sm"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_marginBottom="@dimen/spacing_md"
                app:boxCornerRadiusTopStart="@dimen/radius_input"
                app:boxCornerRadiusTopEnd="@dimen/radius_input"
                app:boxCornerRadiusBottomStart="@dimen/radius_input"
                app:boxCornerRadiusBottomEnd="@dimen/radius_input">
                <AutoCompleteTextView
                    android:id="@+id/actvManager"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:hint="Select Manager" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Importance Spinner -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Importance Level"
            android:textColor="@color/color_text_secondary"
            android:textSize="@dimen/text_sm"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <Spinner
            android:id="@+id/spinnerImportance"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:background="@drawable/bg_input_field"
            android:padding="@dimen/spacing_sm"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Deadline Picker -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deadline Date"
            android:textColor="@color/color_text_secondary"
            android:textSize="@dimen/text_sm"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickDate"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:text="📅 Pick Deadline Date"
            android:textColor="@color/color_text_secondary"
            android:backgroundTint="@color/color_surface"
            android:layout_marginBottom="@dimen/spacing_lg"
            app:strokeColor="@color/color_border"
            app:strokeWidth="1.5dp"
            style="Widget.MaterialComponents.Button.OutlinedButton" />

        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/color_danger"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/btn_create_task"
            style="@style/Widget.SSL.Button.Primary" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_sm"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
